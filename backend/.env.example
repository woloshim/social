# Токен бота от @BotFather
BOT_TOKEN=123456:AA...

# Telegram ID администратора(ов) через запятую — эти пользователи получат роль admin автоматически при первом запуске /start
ADMIN_TELEGRAM_IDS=123456789

# Публичный HTTPS адрес, на котором будет открываться Mini App (нужен для кнопки в боте)
WEBAPP_URL=https://your-domain.example.com

# Порт backend
PORT=3000

# Разрешённый origin для CORS (адрес фронтенда, обычно совпадает с WEBAPP_URL)
CORS_ORIGIN=https://your-domain.example.com
